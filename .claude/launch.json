{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ct-brand-mock",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-I",
        "-c",
        "import functools,http.server,socketserver; H=functools.partial(http.server.SimpleHTTPRequestHandler, directory='/tmp/ct-mock'); socketserver.TCPServer(('127.0.0.1',8431),H).serve_forever()"
      ],
      "port": 8431
    }
  ]
}
