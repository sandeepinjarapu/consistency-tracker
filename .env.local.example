# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local — it's in .gitignore.

# -----------------------------
# Supabase  (Project Settings → API)
# -----------------------------
# Public values (safe to expose in the browser; protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only. Bypasses RLS — admin access. NEVER ship to the browser.
SUPABASE_SECRET_KEY=sb_secret_...

# -----------------------------
# Resend (transactional email for partner invites)
# -----------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# -----------------------------
# App
# -----------------------------
# Used to build absolute URLs in invite emails.
# Local: http://localhost:3000 · Production: your deployed origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret authorizing the weekly partner-summary cron. Sent as
# `Authorization: Bearer <CRON_SECRET>`; set the same value in Vercel.
CRON_SECRET=generate-a-long-random-string
